{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causeway-to-eriu.local/schema/colors.schema.json",
  "title": "Colors",
  "description": "Shared tier-color lookup (altars, boons). Mirrors TIER_COLORS in src/colors.ts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["tiers"],
  "properties": {
    "tiers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["1", "2", "3"],
      "properties": {
        "1": { "$ref": "#/$defs/tierColor" },
        "2": { "$ref": "#/$defs/tierColor" },
        "3": { "$ref": "#/$defs/tierColor" }
      }
    }
  },
  "$defs": {
    "tierColor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rgb", "bg"],
      "properties": {
        "rgb": { "type": "string", "pattern": "^\\d{1,3},\\d{1,3},\\d{1,3}$" },
        "bg": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      }
    }
  }
}
