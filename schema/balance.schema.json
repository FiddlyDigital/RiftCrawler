{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causeway-to-eriu.local/schema/balance.schema.json",
  "title": "BalanceConfig",
  "description": "Top-level gameplay tuning knobs. Mirrors BalanceConfig in src/balance.ts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "player", "progression", "economy", "brands", "ammo", "altars",
    "floors", "boss", "gorgoth", "crystalShards", "spawnRates", "eliteMonsters", "ghosts"
  ],
  "properties": {
    "player": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startingHp", "startingAtk", "xpToNextStart", "xpToNextGrowth", "combatLevelBands"],
      "properties": {
        "startingHp": { "type": "number" },
        "startingAtk": { "type": "number" },
        "xpToNextStart": { "type": "number" },
        "xpToNextGrowth": { "type": "number" },
        "combatLevelBands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["minPlayerLevel"],
            "properties": {
              "minPlayerLevel": { "type": "number" },
              "combatLevel": { "type": "number" },
              "combatLevelFloor": { "type": "number" }
            }
          }
        }
      }
    },
    "progression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tickBaseMs", "tickMinMs", "tickMsPerDungeonLevel", "lineClearScoreBase", "lineClearScoreOverflow"],
      "properties": {
        "tickBaseMs": { "type": "number" },
        "tickMinMs": { "type": "number" },
        "tickMsPerDungeonLevel": { "type": "number" },
        "lineClearScoreBase": { "type": "array", "items": { "type": "number" } },
        "lineClearScoreOverflow": { "type": "number" }
      }
    },
    "economy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["geasaRerollBaseCost", "geasaRerollCostGrowth", "ogmRerollBaseCost", "ogmRerollCostGrowth", "shop"],
      "properties": {
        "geasaRerollBaseCost": { "type": "number" },
        "geasaRerollCostGrowth": { "type": "number" },
        "ogmRerollBaseCost": { "type": "number" },
        "ogmRerollCostGrowth": { "type": "number" },
        "shop": {
          "type": "object",
          "additionalProperties": false,
          "required": ["descentModulo", "descentRemainder", "prices"],
          "properties": {
            "descentModulo": { "type": "number" },
            "descentRemainder": { "type": "number" },
            "prices": {
              "type": "object",
              "additionalProperties": false,
              "required": ["heal", "maxhp", "atk", "ward"],
              "properties": {
                "heal": { "$ref": "#/$defs/priceEntry" },
                "maxhp": { "$ref": "#/$defs/priceEntry" },
                "atk": { "$ref": "#/$defs/priceEntry" },
                "ward": { "$ref": "#/$defs/priceEntry" }
              }
            }
          }
        }
      }
    },
    "brands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxLifetime"],
      "properties": {
        "maxLifetime": { "type": "number" }
      }
    },
    "ammo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["replenishOnDescend", "maxAmmo"],
      "properties": {
        "replenishOnDescend": { "type": "number" },
        "maxAmmo": { "type": "number" }
      }
    },
    "altars": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vaultTierMinFloorT3", "vaultTierMinFloorT2"],
      "properties": {
        "vaultTierMinFloorT3": { "type": "number" },
        "vaultTierMinFloorT2": { "type": "number" }
      }
    },
    "floors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bossFloorInterval", "floorEventInterval", "dungeonRoomChance"],
      "properties": {
        "bossFloorInterval": { "type": "number" },
        "floorEventInterval": { "type": "number" },
        "dungeonRoomChance": { "type": "number" }
      }
    },
    "boss": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseHpFloor1", "baseHpPerDungeonLevel", "baseAtkFloor1", "baseAtkPerDungeonLevel", "combatLevel"],
      "properties": {
        "baseHpFloor1": { "type": "number" },
        "baseHpPerDungeonLevel": { "type": "number" },
        "baseAtkFloor1": { "type": "number" },
        "baseAtkPerDungeonLevel": { "type": "number" },
        "combatLevel": { "type": "number" }
      }
    },
    "gorgoth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxHp", "atk", "xpReward", "combatLevel", "causewayDamagePerRowPerFloor", "causewayChipFloorPct"],
      "properties": {
        "maxHp": { "type": "number" },
        "atk": { "type": "number" },
        "xpReward": { "type": "number" },
        "combatLevel": { "type": "number" },
        "causewayDamagePerRowPerFloor": { "type": "number" },
        "causewayChipFloorPct": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "crystalShards": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseHp", "hpPerDungeonLevel", "baseAtk", "atkPerDungeonLevel"],
      "properties": {
        "baseHp": { "type": "number" },
        "hpPerDungeonLevel": { "type": "number" },
        "baseAtk": { "type": "number" },
        "atkPerDungeonLevel": { "type": "number" }
      }
    },
    "spawnRates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cursedPieceChance", "blessedPieceChance", "stairsForcedAfterBlocks", "stairsRandomChance",
        "merchantChance", "maxTattooTilesPerFloor", "altarChance", "npcChance", "maxNpcTilesPerFloor", "trapWeights",
        "monsterBaseChance", "monsterChancePerDungeonLevel", "monsterChanceCap",
        "hauntedMonsterChanceMult", "monsterWeights", "oPieceAltarChance", "oPieceAltarChanceArchitect"
      ],
      "properties": {
        "cursedPieceChance": { "type": "number" },
        "blessedPieceChance": { "type": "number" },
        "stairsForcedAfterBlocks": { "type": "number" },
        "stairsRandomChance": { "type": "number" },
        "merchantChance": { "type": "number" },
        "maxTattooTilesPerFloor": { "type": "number" },
        "altarChance": { "type": "number" },
        "npcChance": { "type": "number" },
        "maxNpcTilesPerFloor": { "type": "number" },
        "trapWeights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spike", "smoke", "teleport"],
          "properties": {
            "spike": { "type": "number" },
            "smoke": { "type": "number" },
            "teleport": { "type": "number" }
          }
        },
        "monsterBaseChance": { "type": "number" },
        "monsterChancePerDungeonLevel": { "type": "number" },
        "monsterChanceCap": { "type": "number" },
        "hauntedMonsterChanceMult": { "type": "number" },
        "monsterWeights": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "oPieceAltarChance": { "type": "number" },
        "oPieceAltarChanceArchitect": { "type": "number" }
      }
    },
    "eliteMonsters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spawnChance", "hpMult", "atkMult", "combatLevelBonus"],
      "properties": {
        "spawnChance": { "type": "number" },
        "hpMult": { "type": "number" },
        "atkMult": { "type": "number" },
        "combatLevelBonus": { "type": "number" }
      }
    },
    "ghosts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["encounterChance", "levelTolerance", "maxStored"],
      "properties": {
        "encounterChance": { "type": "number" },
        "levelTolerance": { "type": "number" },
        "maxStored": { "type": "number" }
      }
    }
  },
  "$defs": {
    "priceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "perFloor"],
      "properties": {
        "base": { "type": "number" },
        "perFloor": { "type": "number" }
      }
    }
  }
}
