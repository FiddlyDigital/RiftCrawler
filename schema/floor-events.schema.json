{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causeway-to-eriu.local/schema/floor-events.schema.json",
  "title": "FloorEvents",
  "description": "Narrative floor-event encounters with player-chosen options. Mirrors RawFloorEvent in src/dataLoader.ts.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "emoji", "title", "flavor", "options"],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "emoji": { "type": "string", "minLength": 1 },
      "title": { "type": "string", "minLength": 1 },
      "flavor": { "type": "string", "minLength": 1 },
      "options": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "desc", "handler"],
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "desc": { "type": "string", "minLength": 1 },
            "handler": { "type": "string", "minLength": 1 },
            "params": {
              "type": "object",
              "additionalProperties": { "type": "number" }
            },
            "resultMsg": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
