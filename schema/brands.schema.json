{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causeway-to-eriu.local/schema/brands.schema.json",
  "title": "Brands",
  "description": "Ogham Marks (equippable body-slot brands with set bonuses). Mirrors RawBrand in src/dataLoader.ts.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "char", "name", "setSize", "role", "desc", "setDesc"],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "char": { "type": "string", "minLength": 1 },
      "name": { "type": "string", "minLength": 1 },
      "setSize": { "type": "integer", "enum": [2, 3] },
      "role": { "type": "string", "enum": ["offense", "defense", "utility"] },
      "desc": { "type": "string", "minLength": 1 },
      "setDesc": { "type": "string", "minLength": 1 },
      "onEquip": {
        "type": "array",
        "items": { "$ref": "_effect-spec.schema.json" }
      },
      "onSet": {
        "type": "array",
        "items": { "$ref": "_effect-spec.schema.json" }
      }
    }
  }
}
